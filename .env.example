# 이 파일을 복사해 .env로 쓴다. 실제 .env는 커밋하지 않는다(.gitignore).
#
#   cp .env.example .env
#
# ⚠️ Vite 환경변수는 빌드 시점에 번들에 그대로 구워진다.
#    - 값을 바꾸면 개발 서버 재시작(로컬) 또는 재배포(Vercel)를 해야 반영된다.
#    - 브라우저에서 전부 들여다볼 수 있다. 여기에 비밀값을 넣지 않는다.

# 백엔드 API 주소. 비우면 http://localhost:8000 을 쓴다(로컬 개발 기본값).
# WebSocket 주소는 이 값에서 자동 파생된다(https → wss).
# 프로덕션 예: https://ieum.duckdns.org
VITE_API_BASE_URL=http://localhost:8000

# 채팅 GIF 검색용(선택). 둘 다 있으면 GIPHY를 먼저 쓴다. 비우면 GIF 탭이 안내를 띄운다.
# 번들에 노출되는 클라이언트 키이므로 각 대시보드에서 도메인 제한을 걸어둔다.
VITE_GIPHY_KEY=
VITE_TENOR_KEY=
